// ─── GammaBar ─────────────────────────────────────────────────────────────────

function GammaBar({ ticker }: { ticker: Ticker }) {
  const putVal = parseFloat((ticker.putWall || "0").replace(/[$,]/g, ""));
  const callVal = parseFloat((ticker.callWall || "0").replace(/[$,]/g, ""));
  const flipVal = parseFloat((ticker.gammaFlip || "0").replace(/[$,]/g, ""));
  const price = ticker.price;

  if (!putVal || !callVal || !price) return null;

  const allVals = [putVal, callVal, price];
  if (flipVal) allVals.push(flipVal);
  const min = Math.min(...allVals) * 0.99;
  const max = Math.max(...allVals) * 1.01;
  const range = max - min;
  const toPct = (v: number) =>
    Math.max(0, Math.min(100, ((v - min) / range) * 100));

  const pricePct = toPct(price);
  const putPct = toPct(putVal);
  const callPct = toPct(callVal);
  const flipPct = flipVal ? toPct(flipVal) : null;

  const markers = [
    { label: `Put Wall ${ticker.putWall}`, pct: putPct, color: "text-red-400" },
    ...(flipPct !== null
      ? [
          {
            label: `Flip ${ticker.gammaFlip}`,
            pct: flipPct,
            color: "text-amber-400",
          },
        ]
      : []),
    {
      label: `Price $${formatPrice(ticker.price)}`,
      pct: pricePct,
      color: "text-white font-medium",
    },
    {
      label: `Call Wall ${ticker.callWall}`,
      pct: callPct,
      color: "text-emerald-400",
    },
  ].sort((a, b) => a.pct - b.pct);

  return (
    <Card className="p-4 border-card-border bg-card" data-testid="gamma-bar-card">
      <h3 className="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-3">
        Price vs Options Levels
      </h3>
      <div className="relative h-10 bg-muted/40 rounded-lg overflow-hidden">
        <div
          className="absolute top-0 bottom-0 bg-red-500/15 border-r-2 border-red-400"
          style={{ left: 0, width: `${putPct}%` }}
        />
        <div
          className="absolute top-0 bottom-0 bg-emerald-500/15 border-l-2 border-emerald-400"
          style={{ left: `${callPct}%`, right: 0 }}
        />
        {flipPct !== null && (
          <div
            className="absolute top-0 bottom-0 w-0.5 bg-amber-400/70"
            style={{ left: `${flipPct}%` }}
          />
        )}
        <div
          className="absolute top-0 bottom-0 w-1 bg-white shadow-lg shadow-white/30 z-10"
          style={{ left: `${pricePct}%` }}
        />
      </div>
      <div className="flex justify-between mt-2 text-[10px] text-muted-foreground">
        {markers.map((m, i) => (
          <span key={i} className={m.color}>
            {m.label}
          </span>
        ))}
      </div>
    </Card>
  );
}

// ─── NewsItem ─────────────────────────────────────────────────────────────────

function NewsItem({
  item,
  onClick,
}: {
  item: News;
  onClick: () => void;
}) {
  const sentimentColor =
    item.sentiment === "bullish"
      ? "text-emerald-400 bg-emerald-500/10 border-emerald-500/30"
      : item.sentiment === "bearish"
      ? "text-red-400 bg-red-500/10 border-red-500/30"
      : "text-amber-400 bg-amber-500/10 border-amber-500/30";

  const SentimentIcon =
    item.sentiment === "bullish"
      ? TrendingUp
      : item.sentiment === "bearish"
      ? TrendingDown
      : Minus;

  return (
    <div
      className="py-3 px-3 hover:bg-muted/30 transition-colors rounded-lg cursor-pointer"
      data-testid={`news-item-${item.id}`}
      onClick={onClick}
    >
      <div className="flex items-start gap-2.5">
        <div
          className={`p-1 rounded border ${sentimentColor} mt-0.5 flex-shrink-0`}
        >
          <SentimentIcon className="w-3 h-3" />
        </div>
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 mb-0.5">
            {item.relatedTicker && (
              <Badge
                variant="outline"
                className="text-[9px] px-1.5 py-0 h-4 font-semibold tracking-wider"
              >
                {item.relatedTicker}
              </Badge>
            )}
            <span className="text-[10px] text-muted-foreground flex items-center gap-1">
              <Clock className="w-2.5 h-2.5" />
              {timeAgo(item.timestamp)}
            </span>
          </div>
          <p className="text-xs font-medium leading-snug">{item.title}</p>
          <span className="text-[10px] text-muted-foreground mt-1 block">
            {item.source}
          </span>
        </div>
      </div>
    </div>
  );
}

// ─── NewsModal ────────────────────────────────────────────────────────────────

function NewsModal({
  item,
  open,
  onClose,
}: {
  item: News | null;
  open: boolean;
  onClose: () => void;
}) {
  if (!item) return null;

  const sentimentColor =
    item.sentiment === "bullish"
      ? "text-emerald-400 bg-emerald-500/10 border-emerald-500/30"
      : item.sentiment === "bearish"
      ? "text-red-400 bg-red-500/10 border-red-500/30"
      : "text-amber-400 bg-amber-500/10 border-amber-500/30";

  return (
    <Dialog open={open} onOpenChange={(v) => !v && onClose()}>
      <DialogContent className="bg-card border-card-border max-w-lg">
        <DialogHeader>
          <DialogTitle className="text-sm font-bold leading-snug pr-6">
            {item.title}
          </DialogTitle>
          <DialogDescription asChild>
            <div className="space-y-3 pt-2">
              <div className="flex items-center gap-2 flex-wrap">
                {item.relatedTicker && (
                  <Badge
                    variant="outline"
                    className="text-[10px] px-2 py-0.5 font-semibold tracking-wider"
                  >
                    {item.relatedTicker}
                  </Badge>
                )}
                <Badge
                  variant="outline"
                  className={`text-[10px] px-2 py-0.5 font-medium ${sentimentColor}`}
                >
                  {item.sentiment === "bullish"
                    ? "Bullish"
                    : item.sentiment === "bearish"
                    ? "Bearish"
                    : "Neutral"}
                </Badge>
              </div>
              {item.summary && (
                <p className="text-xs text-foreground/80 leading-relaxed">
                  {item.summary}
                </p>
              )}
              <div className="flex items-center gap-3 text-[10px] text-muted-foreground pt-1">
                {item.source && (
                  <span className="font-medium">{item.source}</span>
                )}
                <span className="flex items-center gap-1">
                  <Clock className="w-2.5 h-2.5" />
                  {timeAgo(item.timestamp)}
                </span>
              </div>
              {item.url && (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="inline-block text-[11px] text-primary hover:underline mt-1"
                >
                  Read full article →
                </a>
              )}
            </div>
          </DialogDescription>
        </DialogHeader>
      </DialogContent>
    </Dialog>
  );
}

